<Window x:Class="PrincessCyberGuide.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="👑 Princess CyberGuide" Height="700" Width="950"
        Background="#2D1B3D" Foreground="White" FontFamily="Segoe UI" ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#4A2C6D" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="👑" FontSize="36" Margin="0,0,15,0"/>
                <TextBlock Text="Princess CyberGuide" FontSize="32" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Chat Area -->
        <ScrollViewer Grid.Row="1" Margin="15" VerticalScrollBarVisibility="Auto" x:Name="ChatScrollViewer">
            <StackPanel x:Name="ChatPanel" Margin="10"/>
        </ScrollViewer>

        <!-- Input Area -->
        <Grid Grid.Row="2" Background="#3B2A4F" Margin="10" Height="70">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputBox" Grid.Column="0" Margin="12" 
                     Background="#2D1B3D" Foreground="White" FontSize="16"
                     VerticalContentAlignment="Center" KeyDown="InputBox_KeyDown"
                     BorderBrush="#C026D3" BorderThickness="2" Padding="12"
                     AcceptsReturn="False"/>

            <Button x:Name="SendButton" Grid.Column="1" Content="Send" Margin="5,12,12,12"
                    Width="110" Background="#C026D3" Foreground="White" FontWeight="Bold" FontSize="16"
                    Click="SendButton_Click"/>
        </Grid>
    </Grid>
</Window>
